generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUBSCRIBER
  INVESTOR
  ANALYST
  ADMIN
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

enum FootballFixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum FootballSyncStatus {
  SUCCESS
  FAILED
  RUNNING
}

enum PredictionApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PredictionDataQualityStatus {
  READY
  INSUFFICIENT_DATA
  STALE_ODDS
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  INVESTMENT
  ADJUSTMENT
}

enum WalletTransactionStatus {
  PENDING
  CONFIRMED
  FAILED
  APPROVED
  REJECTED
}

enum AnalystAssignmentStatus {
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum IntelligenceSubmissionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}

model User {
  id             String               @id @default(uuid())
  name           String
  email          String               @unique
  passwordHash   String
  role           UserRole
  status         AccountStatus        @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  resetTokens    PasswordResetToken[]
  auditLogs      AuditLog[]
  loginHistory   LoginHistory[]
  investments    Investment[]
  withdrawalRequests WithdrawalRequest[]
  wallet         InvestorWallet?
  investorAccount InvestorAccount?
  investorAuditLogs InvestorAuditLog[] @relation("InvestorAuditActor")
  investorNotes InvestorNote[] @relation("InvestorNoteAuthor")
  analystAssignments AnalystAssignment[]
  intelligenceSubmissions AnalystIntelligenceSubmission[]
  globalPreference UserGlobalPreference?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model FootballLeague {
  id                  String              @id @default(uuid())
  apiFootballLeagueId Int                 @unique
  name                String
  country             String?
  logoUrl             String?
  season              Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  fixtures            FootballFixture[]
  standings           LeagueStanding[]
  teamStatistics      TeamStatistic[]

  @@index([season])
}

model FootballTeam {
  id                String              @id @default(uuid())
  apiFootballTeamId Int                 @unique
  name              String
  country           String?
  logoUrl           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  homeFixtures      FootballFixture[]   @relation("HomeTeamFixtures")
  awayFixtures      FootballFixture[]   @relation("AwayTeamFixtures")
  standings         LeagueStanding[]
  statistics        TeamStatistic[]
  injuries          PlayerInjury[]
}

model FootballFixture {
  id                   String                @id @default(uuid())
  apiFootballFixtureId Int                   @unique
  leagueId             String
  homeTeamId           String
  awayTeamId           String
  season               Int
  round                String?
  kickoffAt            DateTime
  status               FootballFixtureStatus
  statusShort          String?
  elapsed              Int?
  venue                String?
  referee              String?
  homeScore            Int?
  awayScore            Int?
  raw                  Json
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  league               FootballLeague        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam             FootballTeam          @relation("HomeTeamFixtures", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam             FootballTeam          @relation("AwayTeamFixtures", fields: [awayTeamId], references: [id], onDelete: Cascade)
  injuries             PlayerInjury[]
  headToHeadRecords    HeadToHeadRecord[]
  odds                 MatchOdd[]
  predictions          MatchPrediction[]
  analystAssignments   AnalystAssignment[]
  intelligenceSubmissions AnalystIntelligenceSubmission[]

  @@index([kickoffAt])
  @@index([status])
  @@index([leagueId])
}

model LeagueStanding {
  id        String         @id @default(uuid())
  leagueId  String
  teamId    String
  season    Int
  rank      Int
  points    Int
  played    Int
  won       Int
  drawn     Int
  lost      Int
  goalsFor  Int
  goalsAgainst Int
  raw       Json
  updatedAt DateTime       @updatedAt
  league    FootballLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team      FootballTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([leagueId, teamId, season])
  @@index([season])
}

model TeamStatistic {
  id        String         @id @default(uuid())
  leagueId  String
  teamId    String
  season    Int
  raw       Json
  updatedAt DateTime       @updatedAt
  league    FootballLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team      FootballTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([leagueId, teamId, season])
}

model PlayerInjury {
  id        String           @id @default(uuid())
  fixtureId String?
  teamId    String
  playerName String
  reason    String?
  raw       Json
  updatedAt DateTime         @updatedAt
  fixture   FootballFixture? @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  team      FootballTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([fixtureId])
  @@index([teamId])
}

model HeadToHeadRecord {
  id        String          @id @default(uuid())
  fixtureId String          @unique
  raw       Json
  updatedAt DateTime        @updatedAt
  fixture   FootballFixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model MatchOdd {
  id          String          @id @default(uuid())
  fixtureId   String?
  fixtureApiId Int?
  bookmaker   String
  market      String
  outcome     String
  price       Float
  raw         Json
  updatedAt   DateTime        @updatedAt
  fixture     FootballFixture? @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  predictions MatchPrediction[]

  @@index([fixtureId])
  @@index([fixtureApiId])
}

model MatchPrediction {
  id                 String                      @id @default(uuid())
  fixtureId          String
  oddId              String
  recommendedMarket  String
  predictedOutcome   String
  confidenceScore    Float
  riskScore          Float
  valueRating        String
  explanation        String
  adminNotes         String?
  dataQualityStatus  PredictionDataQualityStatus
  approvalStatus     PredictionApprovalStatus    @default(PENDING)
  edge               Float?
  impliedProbability Float?
  modelProbability   Float?
  staleOdds          Boolean                     @default(false)
  riskyMarket        Boolean                     @default(false)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  fixture            FootballFixture             @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  odd                MatchOdd                    @relation(fields: [oddId], references: [id], onDelete: Restrict)

  @@index([fixtureId])
  @@index([approvalStatus])
}

model PredictionQueue {
  id                 String   @id @default(uuid())
  fixtureId          String
  decisionId         String?
  match              String
  league             String
  kickoffTime        DateTime?
  recommendedMarket  String
  predictedOutcome   String
  confidenceScore    Float
  riskScore          Float
  opportunityScore   Float
  valueScore         Float
  priority           Int      @default(0)
  status             String   @default("NEW")
  predictionType     String   @default("AI_DECISION")
  explanation        String
  reasoning          Json
  warnings           Json
  analystNotes       String?
  featured           Boolean  @default(false)
  source             String   @default("AI_DECISION_ENGINE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  publishedAt        DateTime?
  archivedAt         DateTime?
  reviews            PredictionReview[]
  statusHistory      PredictionStatusHistory[]
  publications       PredictionPublication[]
  notes              PredictionNote[]
  flags              PredictionFlag[]
  notifications      PredictionNotification[]

  @@index([fixtureId])
  @@index([status])
  @@index([league])
  @@index([kickoffTime])
  @@index([confidenceScore])
  @@index([riskScore])
  @@index([priority])
  @@map("prediction_queue")
}

model PredictionReview {
  id           String          @id @default(uuid())
  queueItemId  String
  reviewerId   String?
  status       String
  notes        String?
  createdAt    DateTime        @default(now())
  queueItem    PredictionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@index([queueItemId])
  @@index([reviewerId])
  @@map("prediction_reviews")
}

model PredictionStatusHistory {
  id             String          @id @default(uuid())
  queueItemId    String
  userId         String?
  action         String
  previousStatus String?
  newStatus      String
  reason         String?
  notes          String?
  systemVersion  String
  aiVersion      String
  createdAt      DateTime        @default(now())
  queueItem      PredictionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@index([queueItemId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("prediction_status_history")
}

model PredictionPublication {
  id          String          @id @default(uuid())
  queueItemId String
  channel     String          @default("SUBSCRIBER_PORTAL")
  publishedAt DateTime        @default(now())
  queueItem   PredictionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@index([queueItemId])
  @@map("prediction_publications")
}

model PredictionNote {
  id          String          @id @default(uuid())
  queueItemId String
  userId      String?
  note        String
  createdAt   DateTime        @default(now())
  queueItem   PredictionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@index([queueItemId])
  @@index([userId])
  @@map("prediction_notes")
}

model PredictionFlag {
  id          String          @id @default(uuid())
  queueItemId String
  flag        String
  createdById String?
  createdAt   DateTime        @default(now())
  queueItem   PredictionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@unique([queueItemId, flag])
  @@index([queueItemId])
  @@map("prediction_flags")
}

model PredictionNotification {
  id          String          @id @default(uuid())
  queueItemId String
  channel     String
  status      String          @default("PENDING")
  payload     Json
  createdAt   DateTime        @default(now())
  sentAt      DateTime?
  queueItem   PredictionQueue @relation(fields: [queueItemId], references: [id], onDelete: Cascade)

  @@index([queueItemId])
  @@index([channel])
  @@index([status])
  @@map("prediction_notifications")
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  action      String
  entityType  String
  entityId    String?
  details     Json?
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  success   Boolean
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([email])
  @@index([createdAt])
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model InvestmentPlan {
  id                         String       @id @default(uuid())
  name                       String
  description                String
  minimumInvestmentCents     Int
  maximumInvestmentCents     Int
  historicalPerformanceNote  String
  riskDisclosure             String
  active                     Boolean      @default(true)
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt
  investments                Investment[]
}

model Investment {
  id                    String             @id @default(uuid())
  userId                String
  planId                String
  amountCents           Int
  currentValueCents     Int
  weeklyRoiPercent      Float              @default(0)
  lifetimeRoiPercent    Float              @default(0)
  status                InvestmentStatus   @default(ACTIVE)
  createdAt             DateTime           @default(now())
  completedAt           DateTime?
  user                  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  InvestmentPlan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  performanceReports    PerformanceReport[]

  @@index([userId])
  @@index([status])
}

model PerformanceReport {
  id                    String      @id @default(uuid())
  investmentId          String
  periodType            String
  periodStart           DateTime
  periodEnd             DateTime
  summary               String
  roiPercent            Float
  portfolioValueCents   Int
  createdAt             DateTime    @default(now())
  investment            Investment  @relation(fields: [investmentId], references: [id], onDelete: Cascade)

  @@index([investmentId])
  @@index([periodType])
}

model WithdrawalRequest {
  id              String           @id @default(uuid())
  userId          String
  amountCents     Int
  status          WithdrawalStatus @default(PENDING)
  requestedAt     DateTime         @default(now())
  reviewedAt      DateTime?
  adminNotes      String?
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model InvestorAccount {
  id                        String                    @id @default(uuid())
  userId                    String                    @unique
  tier                      String                    @default("Founding Investor")
  kycStatus                 String                    @default("PENDING_REVIEW")
  agreementStatus           String                    @default("PENDING_SIGNATURE")
  paymentMethod             String                    @default("Placeholder - not connected")
  withdrawalMethod          String                    @default("Placeholder - admin review required")
  riskNotice                String                    @default("Capital is at risk. Historical performance is not a guarantee of future results.")
  startDate                 DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance                   InvestorBalance?
  distributions             InvestorDistribution[]
  reports                   InvestorPortalReport[]
  auditLogs                 InvestorAuditLog[]
  notes                     InvestorNote[]

  @@map("investor_accounts")
}

model InvestorBalance {
  id                              String          @id @default(uuid())
  investorAccountId               String          @unique
  totalCapitalCents               Int             @default(0)
  activeInvestmentBalanceCents    Int             @default(0)
  weeklyEarningsCents             Int             @default(0)
  totalEarningsCents              Int             @default(0)
  pendingDistributionCents        Int             @default(0)
  paidDistributionCents           Int             @default(0)
  createdAt                       DateTime        @default(now())
  updatedAt                       DateTime        @updatedAt
  investorAccount                 InvestorAccount @relation(fields: [investorAccountId], references: [id], onDelete: Cascade)

  @@map("investor_balances")
}

model InvestorDistributionBatch {
  id                         String                 @id @default(uuid())
  weekStart                  DateTime
  weekEnd                    DateTime
  status                     String                 @default("PENDING_APPROVAL")
  totalCapitalCents          Int                    @default(0)
  totalGrossReturnCents      Int                    @default(0)
  totalNetDistributionCents  Int                    @default(0)
  investorCount              Int                    @default(0)
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  distributions              InvestorDistribution[]

  @@index([status])
  @@index([weekStart, weekEnd])
  @@map("investor_distribution_batches")
}

model InvestorDistribution {
  id                       String                     @id @default(uuid())
  investorAccountId        String
  batchId                  String?
  periodStart              DateTime
  periodEnd                DateTime
  capitalBaseCents         Int
  returnRatePercent        Float                      @default(0)
  grossReturnCents         Int                        @default(0)
  platformFeeCents         Int                        @default(0)
  netDistributionCents     Int                        @default(0)
  status                   String                     @default("PENDING_CALCULATION")
  adminNotes               String?
  calculatedAt             DateTime?
  approvedAt               DateTime?
  paidAt                   DateTime?
  failedAt                 DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  investorAccount          InvestorAccount            @relation(fields: [investorAccountId], references: [id], onDelete: Cascade)
  batch                    InvestorDistributionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([investorAccountId])
  @@index([batchId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("investor_distributions")
}

model InvestorPortalReport {
  id                 String          @id @default(uuid())
  investorAccountId  String
  periodType         String
  title              String
  summary            String
  earningsCents      Int             @default(0)
  capitalCents       Int             @default(0)
  roiPercent         Float           @default(0)
  downloadUrl        String?
  generatedAt        DateTime        @default(now())
  investorAccount    InvestorAccount @relation(fields: [investorAccountId], references: [id], onDelete: Cascade)

  @@index([investorAccountId])
  @@index([periodType])
  @@map("investor_reports")
}

model InvestorAuditLog {
  id                 String           @id @default(uuid())
  investorAccountId  String?
  actorUserId        String?
  action             String
  entityType         String
  entityId           String?
  details            Json?
  createdAt          DateTime         @default(now())
  investorAccount    InvestorAccount? @relation(fields: [investorAccountId], references: [id], onDelete: SetNull)
  actor              User?            @relation("InvestorAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([investorAccountId])
  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
  @@map("investor_audit_logs")
}

model InvestorNote {
  id                 String          @id @default(uuid())
  investorAccountId  String
  authorUserId       String?
  note               String
  createdAt          DateTime        @default(now())
  investorAccount    InvestorAccount @relation(fields: [investorAccountId], references: [id], onDelete: Cascade)
  author             User?           @relation("InvestorNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([investorAccountId])
  @@index([authorUserId])
  @@map("investor_notes")
}

model InvestorWallet {
  id                     String              @id @default(uuid())
  userId                 String              @unique
  availableBalanceCents  Int                 @default(0)
  pendingBalanceCents    Int                 @default(0)
  investmentBalanceCents Int                 @default(0)
  withdrawalBalanceCents Int                 @default(0)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  user                   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions           WalletTransaction[]
}

model LanguageSetting {
  code       String   @id
  name       String
  nativeName String
  direction  String   @default("ltr")
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("languages")
}

model CurrencySetting {
  code                   String   @id
  name                   String
  symbol                 String
  placeholderRateFromUsd Float    @default(1)
  enabled                Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("currencies")
}

model ExchangeRatePlaceholder {
  id           String   @id @default(uuid())
  baseCurrency String   @default("USD")
  currency     String
  rate         Float
  source       String   @default("PLACEHOLDER")
  createdAt    DateTime @default(now())

  @@index([baseCurrency, currency])
  @@map("exchange_rate_placeholders")
}

model UserGlobalPreference {
  id                String   @id @default(uuid())
  userId            String   @unique
  language          String   @default("en")
  currency          String   @default("USD")
  timezone          String   @default("UTC")
  country           String   @default("US")
  region            String   @default("North America")
  measurementSystem String   @default("metric")
  dateFormat        String   @default("MM/DD/YYYY")
  numberFormat      String   @default("en-US")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model CountrySetting {
  countryCode       String   @id
  countryName       String
  region            String
  defaultLanguage   String
  defaultCurrency   String
  defaultTimezone   String
  measurementSystem String   @default("metric")
  dateFormat        String
  numberFormat      String
  enabled           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("country_settings")
}

model TimezoneSetting {
  id        String   @id
  label     String
  offset    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("timezone_settings")
}

model WalletTransaction {
  id                 String                  @id @default(uuid())
  walletId           String
  type               WalletTransactionType
  status             WalletTransactionStatus
  amountCents        Int
  currency           String                  @default("USD")
  externalPaymentId  String?                 @unique
  invoiceUrl         String?
  metadata           Json?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  wallet             InvestorWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([status])
}

model AnalystAssignment {
  id            String                  @id @default(uuid())
  analystId     String
  fixtureId     String
  leagueName    String
  status        AnalystAssignmentStatus @default(ASSIGNED)
  adminNotes    String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  analyst       User                    @relation(fields: [analystId], references: [id], onDelete: Cascade)
  fixture       FootballFixture         @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@unique([analystId, fixtureId])
  @@index([analystId])
  @@index([fixtureId])
  @@index([status])
}

model AnalystIntelligenceSubmission {
  id                   String                       @id @default(uuid())
  analystId            String
  fixtureId            String
  leagueName           String
  market               String
  prediction           String
  confidence           Int
  riskLevel            String
  detailedReasoning    String
  supportingStatistics String
  sourceNotes          String
  briefExplanation     String
  recommendedStake     String
  adminNotes           String?
  status               IntelligenceSubmissionStatus @default(DRAFT)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  publishedAt          DateTime?
  analyst              User                         @relation(fields: [analystId], references: [id], onDelete: Cascade)
  fixture              FootballFixture              @relation(fields: [fixtureId], references: [id], onDelete: Cascade)

  @@index([analystId])
  @@index([fixtureId])
  @@index([status])
}

model FootballSyncRun {
  id          String             @id @default(uuid())
  provider    String
  jobName     String
  status      FootballSyncStatus
  startedAt   DateTime           @default(now())
  finishedAt  DateTime?
  message     String?
  recordsRead Int                @default(0)
  recordsSaved Int               @default(0)
}
