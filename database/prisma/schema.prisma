generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUBSCRIBER
  INVESTOR
  ANALYST
  ADMIN
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

enum FootballFixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum FootballSyncStatus {
  SUCCESS
  FAILED
  RUNNING
}

model User {
  id             String               @id @default(uuid())
  name           String
  email          String               @unique
  passwordHash   String
  role           UserRole
  status         AccountStatus        @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  resetTokens    PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model FootballLeague {
  id                  String              @id @default(uuid())
  apiFootballLeagueId Int                 @unique
  name                String
  country             String?
  logoUrl             String?
  season              Int
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  fixtures            FootballFixture[]
  standings           LeagueStanding[]
  teamStatistics      TeamStatistic[]

  @@index([season])
}

model FootballTeam {
  id                String              @id @default(uuid())
  apiFootballTeamId Int                 @unique
  name              String
  country           String?
  logoUrl           String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  homeFixtures      FootballFixture[]   @relation("HomeTeamFixtures")
  awayFixtures      FootballFixture[]   @relation("AwayTeamFixtures")
  standings         LeagueStanding[]
  statistics        TeamStatistic[]
  injuries          PlayerInjury[]
}

model FootballFixture {
  id                   String                @id @default(uuid())
  apiFootballFixtureId Int                   @unique
  leagueId             String
  homeTeamId           String
  awayTeamId           String
  season               Int
  round                String?
  kickoffAt            DateTime
  status               FootballFixtureStatus
  statusShort          String?
  elapsed              Int?
  venue                String?
  referee              String?
  homeScore            Int?
  awayScore            Int?
  raw                  Json
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  league               FootballLeague        @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam             FootballTeam          @relation("HomeTeamFixtures", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam             FootballTeam          @relation("AwayTeamFixtures", fields: [awayTeamId], references: [id], onDelete: Cascade)
  injuries             PlayerInjury[]
  headToHeadRecords    HeadToHeadRecord[]
  odds                 MatchOdd[]

  @@index([kickoffAt])
  @@index([status])
  @@index([leagueId])
}

model LeagueStanding {
  id        String         @id @default(uuid())
  leagueId  String
  teamId    String
  season    Int
  rank      Int
  points    Int
  played    Int
  won       Int
  drawn     Int
  lost      Int
  goalsFor  Int
  goalsAgainst Int
  raw       Json
  updatedAt DateTime       @updatedAt
  league    FootballLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team      FootballTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([leagueId, teamId, season])
  @@index([season])
}

model TeamStatistic {
  id        String         @id @default(uuid())
  leagueId  String
  teamId    String
  season    Int
  raw       Json
  updatedAt DateTime       @updatedAt
  league    FootballLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team      FootballTeam   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([leagueId, teamId, season])
}

model PlayerInjury {
  id        String           @id @default(uuid())
  fixtureId String?
  teamId    String
  playerName String
  reason    String?
  raw       Json
  updatedAt DateTime         @updatedAt
  fixture   FootballFixture? @relation(fields: [fixtureId], references: [id], onDelete: SetNull)
  team      FootballTeam     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([fixtureId])
  @@index([teamId])
}

model HeadToHeadRecord {
  id        String          @id @default(uuid())
  fixtureId String          @unique
  raw       Json
  updatedAt DateTime        @updatedAt
  fixture   FootballFixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
}

model MatchOdd {
  id          String          @id @default(uuid())
  fixtureId   String?
  fixtureApiId Int?
  bookmaker   String
  market      String
  outcome     String
  price       Float
  raw         Json
  updatedAt   DateTime        @updatedAt
  fixture     FootballFixture? @relation(fields: [fixtureId], references: [id], onDelete: SetNull)

  @@index([fixtureId])
  @@index([fixtureApiId])
}

model FootballSyncRun {
  id          String             @id @default(uuid())
  provider    String
  jobName     String
  status      FootballSyncStatus
  startedAt   DateTime           @default(now())
  finishedAt  DateTime?
  message     String?
  recordsRead Int                @default(0)
  recordsSaved Int               @default(0)
}
