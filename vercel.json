{
  "version": 2,
  "installCommand": "npm run install:backend",
  "buildCommand": "npm run build:backend",
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node@latest"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/backend/api/index.ts"
    }
  ]
}
