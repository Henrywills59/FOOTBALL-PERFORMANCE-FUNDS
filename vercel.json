{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build -w shared && npm run prisma:generate -w database && npm run build -w backend && npm run build -w frontend",
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node@latest"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/index.ts"
    },
    {
      "src": "/health",
      "dest": "/backend/api/index.ts"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}
